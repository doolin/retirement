<form method="post" action="/calculate">
  <label>Scenario Name
    <input type="text" name="name" value="My Plan">
  </label>

  <label>Current Savings ($)
    <input type="number" name="savings" value="500000" step="1000">
  </label>

  <label>Annual Income ($)
    <input type="number" name="annual_income" value="80000" step="1000">
  </label>

  <label>Annual Expenses ($)
    <input type="number" name="annual_expenses" value="50000" step="1000">
  </label>

  <label>Expected Return Rate
    <input type="number" name="return_rate" value="0.07" step="0.01" min="0" max="0.30">
  </label>

  <label>Portfolio Allocation
    <select name="portfolio">
      <option value="">None (use return rate above)</option>
      <option value="aggressive">Aggressive (70% stocks, 20% intl, 10% bonds)</option>
      <option value="moderate" selected>Moderate (40% stocks, 30% bonds, 15% RE, 15% intl)</option>
      <option value="conservative">Conservative (50% bonds, 20% stocks, 20% cash, 10% RE)</option>
    </select>
  </label>

  <button type="submit">Calculate 30-Year Projection</button>
</form>
